# Modular Bash entrypoint for the Robotics Development Environment.
# Source this file from any repository location; it does not modify ~/.bashrc.

# Shell customizations only make sense in an interactive Bash session.
case $- in
    *i*) ;;
    *) return ;;
esac

# Resolve modules relative to this file instead of assuming an install path.
_rde_bash_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

# Module filenames begin with numbers so normal shell glob order is explicit.
for _rde_module in "${_rde_bash_dir}"/modules/*.sh; do
    if [[ -r "${_rde_module}" ]]; then
        source "${_rde_module}"
    fi
done

unset _rde_module _rde_bash_dir
